{
  "name": "claude-desk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Claude Desk — Web Dashboard toàn diện để quản lý, giám sát và điều khiển Claude Code",
  "scripts": {
    "start": "node server/dist/index.js",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --port 5173",
    "build": "vite build && tsc -p server/tsconfig.json",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build",
    "setup": "npm install && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.40.0",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "^0.378.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
